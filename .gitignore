# ===========================================
# Git privat de desenvolupament
#
# Aquest repo és PRIVAT — mai connectat a GitHub directament.
# Flux publicació: dev/ → (revisió /gitoss) → gitoss/ → GitHub
# Remote futur: Nostromo (NAS, backup privat)
#
# ⚠️ PARANOIC MODE: tot el que pugui contenir secrets,
# binaris, o dades personals està exclòs.
# ===========================================

# =====================
# SECRETS — ZONA ZERO
# =====================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.cer
*.crt
*secret*
*credential*
*token*
!**/token*.py
!**/secret*.py
.nat_secrets

# =====================
# BINARIS I BUILDS
# =====================

# Binaris del projecte
qdrant
nexe

# Build artifacts
dist/
build/
*.egg-info/
Install Nexe.app/
InstallNexe.app/
installer/swift-wizard/.build/

# Releases (DMGs, PKGs — van a GitHub Releases, no al repo)
releases/
*.dmg
*.pkg

# Dev tray app (compilat local)
Nexe.app/

# =====================
# RUNTIME I DADES
# =====================

# Storage (124 GB! — Qdrant vectors, DBs, logs de producció)
storage/
*.db
*.sqlite
*.log
logs/

# Markers runtime
.qdrant-initialized

# Snapshots Qdrant
snapshots/

# User uploads (poden contenir dades personals)
plugins/web_ui_module/static/uploads/

# Cache personalitat
personality/.module_cache.json

# =====================
# PYTHON
# =====================
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
ENV/

# Test/coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# =====================
# DEV TOOLS I IDE
# =====================
.claude/
.ruff_cache/
*.code-workspace
dev-tools/run_all_day.sh
dev-tools/logs/

# Fitxers generats/temporals
COMMANDS.md
TESTING_REPORT.md

# =====================
# OS
# =====================
.DS_Store
Thumbs.db

# =====================
# FITXERS ACCIDENTALS
# =====================
# (generats per errors de CLI: --output, --help)
--output
--help
