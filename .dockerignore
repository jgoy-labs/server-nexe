# Secrets — NEVER include in Docker image
.env

# Virtual environment
venv/
.venv/

# Storage (runtime data, models, snapshots)
storage/
snapshots/

# Qdrant binary (downloaded at build time for correct platform)
qdrant

# Git history
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Tests and dev tools
tests/
.pytest_cache/
pytest.ini
pytest-full.ini
dev-tools/
.coverage
.coveragerc
.ruff_cache/

# IDE / editor
.vscode/
.idea/
.claude/
*.code-workspace

# macOS artifacts
*.dmg
*.pkg
*.app
Install Nexe.app/
Nexe.app/
.DS_Store

# Documentation (not needed in container)
diari/
*.md
!knowledge/**/*.md
CHANGELOG.md
CONTRIBUTING.md
SECURITY.md
LICENSE
