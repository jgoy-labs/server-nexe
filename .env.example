# ────────────────────────────────────────────────────────
# Nexe Server 0.8 — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
# ────────────────────────────────────────────────────────

# --- Required secrets ---
NEXE_PRIMARY_API_KEY=<generate-with-python-secrets-token-hex-32>
NEXE_CSRF_SECRET=<generate-with-python-secrets-token-hex-32>
# Optional: IPs addicionals autoritzades per al bootstrap (coma-separades)
# NEXE_VPN_ALLOWED_IPS=10.0.0.1,192.168.1.100

# --- Environment ---
NEXE_ENV=production
NEXE_LOG_LEVEL=INFO
NEXE_LANG=ca

# --- Modules ---
NEXE_APPROVED_MODULES=security,llama_cpp_module,mlx_module,ollama_module,web_ui_module

# --- Model ---
NEXE_DEFAULT_MODEL=https://huggingface.co/microsoft/Phi-3.5-mini-instruct-gguf/resolve/main/Phi-3.5-mini-instruct-Q4_K_M.gguf
NEXE_MODEL_ENGINE=llama_cpp
NEXE_LLAMA_CPP_MODEL=storage/models/Phi-3.5-mini-instruct-Q4_K_M.gguf

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Optional: path custom al binari Qdrant (per defecte: <projecte>/qdrant)
# NEXE_QDRANT_BIN=/path/to/qdrant
# Optional: set if Qdrant is deployed with authentication enabled
# QDRANT_API_KEY=<generate-with-python-secrets-token-hex-32>

# --- Ollama ---
NEXE_OLLAMA_HOST=http://localhost:11434
NEXE_OLLAMA_MODEL=llama3.2

# --- MLX (Apple Silicon) ---
# NEXE_MLX_MODEL=mlx-community/Llama-3.2-3B-Instruct-4bit

# --- Llama.cpp ---
# NEXE_LLAMA_CPP_GPU_LAYERS=0
# NEXE_LLAMA_CPP_N_CTX=4096
# NEXE_LLAMA_CPP_THREADS=4

# --- Prompt ---
NEXE_PROMPT_TIER=full

# --- Server URL (for CLI and web_ui) ---
NEXE_API_BASE_URL=http://127.0.0.1:9119

# --- Security ---
# NEXE_ADMIN_API_KEY=<generate-with-python-secrets-token-hex-32>
NEXE_DEV_MODE=false

# --- Rate Limiting ---
# NEXE_RATE_LIMIT_CHAT=60/minute
# NEXE_RATE_LIMIT_MEMORY=30/minute
# NEXE_RATE_LIMIT_RAG=30/minute
# NEXE_RATE_LIMIT_UPLOAD=10/minute
# NEXE_RATE_LIMIT_DEFAULT=120/minute

# --- Bootstrap ---
NEXE_BOOTSTRAP_DISPLAY=true
NEXE_BOOTSTRAP_TTL=30

# --- Auto-Clean ---
NEXE_AUTO_CLEAN_ENABLED=false
NEXE_AUTO_CLEAN_DRY_RUN=true

# --- Timeouts (seconds) ---
NEXE_QDRANT_TIMEOUT=5.0
NEXE_QDRANT_HEALTH_TIMEOUT=2.0
NEXE_SQLITE_PRELOAD_TIMEOUT=10.0
NEXE_OLLAMA_HEALTH_TIMEOUT=5.0
NEXE_OLLAMA_UNLOAD_TIMEOUT=10.0

# --- Ollama native compatibility ---
# OLLAMA_HOST=localhost  # Suportat com a fallback de NEXE_OLLAMA_HOST
