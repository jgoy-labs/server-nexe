# Nexe Server Configuration Example
# Copy this file to .env and fill in the values

# CRITICAL SECURITY SETTINGS
# Generate these with: openssl rand -hex 32
NEXE_PRIMARY_API_KEY=<generate-with-openssl-rand-hex-32>
NEXE_CSRF_SECRET=<generate-with-openssl-rand-hex-32>

# Environment mode (development | production)
NEXE_ENV=production

# Logging level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
NEXE_LOG_LEVEL=INFO

# Approved modules (comma-separated list)
# Available: security, llama_cpp_module, mlx_module, ollama_module, web_ui_module
NEXE_APPROVED_MODULES=security,llama_cpp_module,mlx_module,ollama_module,web_ui_module

# Language (ca | en | es)
NEXE_LANG=ca

# Model configuration
NEXE_DEFAULT_MODEL=https://huggingface.co/microsoft/Phi-3.5-mini-instruct-gguf/resolve/main/Phi-3.5-mini-instruct-Q4_K_M.gguf
NEXE_MODEL_ENGINE=llama_cpp

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=<generate-with-openssl-rand-hex-32>  # Optional: only if Qdrant is exposed remotely

# Configurable timeouts (seconds)
NEXE_QDRANT_TIMEOUT=5.0
NEXE_SQLITE_PRELOAD_TIMEOUT=10.0
NEXE_OLLAMA_HEALTH_TIMEOUT=5.0
NEXE_OLLAMA_UNLOAD_TIMEOUT=10.0

# Local model path
NEXE_LLAMA_CPP_MODEL=storage/models/Phi-3.5-mini-instruct-Q4_K_M.gguf
