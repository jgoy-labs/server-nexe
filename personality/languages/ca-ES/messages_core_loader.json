  "sys_modules_removed": "{count} mòduls eliminats de sys.modules",
  "success": "Mòdul {module} descarregat correctament",
  "error": "Error descarregant mòdul {module}: {error}"
 },
 
 "initialization": {
  "method_found": "Mètode d'inicialització trobat: {method}",
  "method_called": "Mètode {method} executat per {module}",
  "method_error": "Error executant {method}: {error}",
  "no_init_method": "Cap mètode d'inicialització trobat per {module}"
 },
 
 "loader": {
  "patterns": {
   "api_module": "api_{module_name}.py",
   "api_generic": "api.py",
   "main": "main.py",
   "init": "__init__.py",
   "module_name": "{module_name}.py",
   "module_generic": "module.py",
   "app": "app.py"
  },
  "file_extensions": {
   "python": ".py"
  },
  "ignore_prefixes": {
   "test": "test_",
   "underscore": "_",
   "dot": "."
  },
  "ignore_files": {
   "setup": "setup"
  },
  "debug": {
   "tried_patterns": "Provats: {patterns}",
   "found_api_file": "Fitxer d'API trobat: {file}",
   "fallback_api_file": "Usant fitxer d'API alternatiu: {file}",
   "using_module_as_instance": "Usant el mòdul mateix com a instància per {module}",
   "cannot_create_spec": "No es pot crear especificació per {file}",
   "called_method": "Mètode {method} cridat per {module}",
   "cleanup_completed": "Neteja de recursos completada per {module}",
   "error_calling_method": "Error cridant {method}: {error}",
   "error_calling_method_unload": "Error cridant {method} durant la descàrrega: {error}",
   "reloading_module": "Recarregant mòdul {module}"
  },
  "module_name_prefix": "module_{module_name}_{id}",
  "init_methods": {
   "init": "init",
   "initialize": "initialize",
   "setup": "setup",
   "start_up": "start_up",
   "on_load": "on_load"
  },
  "cleanup_methods": {
   "cleanup": "cleanup",
   "shutdown": "shutdown",
   "teardown": "teardown",
   "dispose": "dispose",
   "on_unload": "on_unload"
  },
  "common_attributes": {
   "app": "app",
   "router": "router",
   "api": "api",
   "module": "module",
   "instance": "instance",
   "main": "main"
  },
  "factory_functions": {
   "create_module": "create_module",
   "create_app": "create_app",
   "create": "create",
   "init": "init"
  }
 }
}