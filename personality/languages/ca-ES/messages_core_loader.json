  "validating": "Validant mòdul {module}",
  "initializing": "Inicialitzant mòdul {module}",
  "success": "Mòdul {module} carregat correctament",
  "error": "Error carregant mòdul {module}: {error}",
  "cleanup": "Netejant recursos per {module}"
 },
 
 "validation": {
  "instance_missing": "Instància del mòdul no vàlida",
